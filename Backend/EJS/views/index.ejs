<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Weekday Warrior</title>
</head>

<body>

  <ul>
    <% for (let i = 0; i < bowl.length; i++) { %>
    <li><%= bowl[i] %></li>
    <% } %>
  </ul>

  <form action="/" method="POST">
    <input type="text" name="newFruit" placeholder="Enter new item" />
    <button type="submit">Add Item</button>
  </form>
</body>

</html>